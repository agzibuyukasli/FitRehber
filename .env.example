# ═══════════════════════════════════════════════
#  FitRehber – Ortam Değişkenleri Şablonu
#  Bu dosyayı kopyalayıp ".env" olarak kaydet.
#  .env asla git'e eklenmemeli!
# ═══════════════════════════════════════════════

# ── SQL Server ──────────────────────────────────
# En az 8 karakter, büyük/küçük harf + rakam + özel karakter zorunlu
SQL_SA_PASSWORD=YourStrong!Passw0rd

# ── Redis ───────────────────────────────────────
REDIS_PASSWORD=redis_secret_password

# ── JWT ─────────────────────────────────────────
# En az 32 karakter, rastgele ve güçlü bir değer kullan
JWT_SECRET_KEY=change-me-to-a-very-long-random-secret-key-min-32-chars

# ── SMTP (Gmail örneği) ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=fitrehber7@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=fitrehber7@gmail.com

# ── OpenRouter AI ───────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Redis ───────────────────────────────────────
# docker-compose içinde servis adı "redis" olduğundan değiştirme
REDIS_HOST=redis
REDIS_PORT=6379

# ── Elasticsearch ────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# ── URL Ayarları ────────────────────────────────
# Sunucudan dışarıya açılan frontend adresi
FRONTEND_URL=http://localhost:3000
# Tarayıcının API'ye erişeceği adres (public)
API_PUBLIC_URL=http://localhost:8080
