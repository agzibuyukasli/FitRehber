{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore": "Error"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=sqlserver,1433;Database=DietitianClinicDB;User Id=sa;Password=REPLACED_BY_ENV;Encrypt=False;TrustServerCertificate=True;"
  },
  "Redis": {
    "ConnectionString": "redis:6379",
    "DefaultExpiryMinutes": 5
  },
  "Elasticsearch": {
    "Url": "http://elasticsearch:9200",
    "IndexFormat": "fitrehber-logs-{0:yyyy.MM.dd}"
  },
  "Jwt": {
    "SecretKey": "REPLACED_BY_ENV",
    "AccessTokenExpiryMinutes": 30,
    "RefreshTokenExpiryDays": 7
  }
}
